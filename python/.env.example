# 天勤量化账号配置
# 复制此文件为 .env，填入真实账号密码
# .env 文件已被 .gitignore 忽略，不会上传到 GitHub

TQ_ACCOUNT=你的天勤账号
TQ_PASSWORD=你的天勤密码

# WebSocket 服务端口（默认 8765，与 Electron 前端对应）
WS_PORT=8765

# 默认订阅品种（逗号分隔，可在前端动态切换）
DEFAULT_SYMBOLS=SHFE.rb2505

# K 线周期（秒）：60=1分钟, 300=5分钟, 3600=1小时
KLINE_PERIOD=60

# 历史 K 线数量
KLINE_COUNT=300
